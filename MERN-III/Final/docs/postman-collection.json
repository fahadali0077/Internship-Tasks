{
  "info": {
    "name": "MERNShop API",
    "description": "Complete REST API collection for MERNShop — Node.js + Express + MongoDB + JWT",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/v1/auth/register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"Password1\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('accessToken', pm.response.json().data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"Password1\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('accessToken', pm.response.json().data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/v1/auth/me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/me",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] }
          }
        },
        {
          "name": "POST /api/v1/auth/refresh",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/refresh"
          }
        },
        {
          "name": "POST /api/v1/auth/logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/logout"
          }
        },
        {
          "name": "POST /api/v1/auth/forgot-password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane@example.com\"\n}" }
          }
        },
        {
          "name": "POST /api/v1/auth/reset-password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/reset-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"<reset-token-from-email>\",\n  \"password\": \"NewPassword1\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "GET /api/v1/products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?page=1&limit=12&sort=price-asc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "12" },
                { "key": "sort", "value": "price-asc" },
                { "key": "category", "value": "Electronics", "disabled": true },
                { "key": "search", "value": "laptop", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "GET /api/v1/products/stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/products/stats"
          }
        },
        {
          "name": "GET /api/v1/products/:id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/products/{{productId}}"
          }
        },
        {
          "name": "POST /api/v1/products",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/products",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wireless Headphones\",\n  \"price\": 79.99,\n  \"image\": \"https://example.com/headphones.jpg\",\n  \"category\": \"Electronics\",\n  \"stock\": 50,\n  \"description\": \"High-quality wireless headphones\"\n}"
            }
          }
        },
        {
          "name": "PUT /api/v1/products/:id",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/products/{{productId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 69.99,\n  \"stock\": 45\n}" }
          }
        },
        {
          "name": "DELETE /api/v1/products/:id",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/products/{{productId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] }
          }
        },
        {
          "name": "POST /api/v1/products/:id/image",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/products/{{productId}}/image",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "body": { "mode": "formdata", "formdata": [{ "key": "image", "type": "file", "src": "" }] }
          }
        },
        {
          "name": "POST /api/v1/products/:id/reviews",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/products/{{productId}}/reviews",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Excellent product!\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "POST /api/v1/orders",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/orders",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"productId\": \"{{productId}}\", \"qty\": 2 }\n  ],\n  \"shippingAddress\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"Lahore\",\n    \"country\": \"PK\"\n  }\n}"
            }
          }
        },
        {
          "name": "GET /api/v1/orders/my",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders/my?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "orders", "my"],
              "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] }
          }
        },
        {
          "name": "GET /api/v1/orders (admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/orders",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] }
          }
        },
        {
          "name": "PUT /api/v1/orders/:id/status (admin)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}/status",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"shipped\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Users (admin)",
      "item": [
        {
          "name": "GET /api/v1/users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/users?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"],
              "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }, { "key": "search", "value": "", "disabled": true }]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] }
          }
        },
        {
          "name": "GET /api/v1/users/:id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/{{userId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] }
          }
        },
        {
          "name": "PUT /api/v1/users/:id/role",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/users/{{userId}}/role",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"moderator\"\n}" }
          }
        },
        {
          "name": "DELETE /api/v1/users/:id",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/users/{{userId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] }
          }
        }
      ]
    }
  ]
}
